<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:layoutDirection="locale">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:elevation="4dp">

        <!-- Logo Row -->
        <include layout="@layout/layout_appbar" />
    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginTop="64dp">

        <!-- Section Title + Filter Chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/nav_chats"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:paddingBottom="12dp" />

            <!-- Filter Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="start">

                <TextView
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/filter_all"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_chip_selected"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/chipUnread"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/str___________"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/chipFavorite"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/favorites_tab"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="8dp"
            android:background="@color/bg_screen" />

        <!-- Shimmer Loading -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white">
                <include layout="@layout/item_shimmer_conversation" />
                <include layout="@layout/item_shimmer_conversation" />
                <include layout="@layout/item_shimmer_conversation" />
                <include layout="@layout/item_shimmer_conversation" />
            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- Conversation List -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvConversations"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/white"
                android:clipToPadding="false" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_chat_empty"
                android:alpha="0.4" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/str________________"
                android:textSize="16sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Error State -->
        <LinearLayout
            android:id="@+id/layoutError"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_error"
                android:alpha="0.5" />

            <TextView
                android:id="@+id/tvErrorMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/error_occurred"
                android:textSize="15sp"
                android:gravity="center"
                android:textColor="@color/text_secondary" />

            <Button
                android:id="@+id/btnRetry"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:text="@string/str_______________"
                android:paddingHorizontal="24dp"
                android:backgroundTint="@color/find_primary"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── Bottom Nav ── -->
    <include
        android:id="@+id/cvBottomNav"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
