<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/find_gray_bg"
    android:layoutDirection="locale">

    <!-- ── Sticky Header ── -->
    <LinearLayout
        android:id="@+id/llStickyHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_primary"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Top bar -->
        <include layout="@layout/layout_appbar" />

        <!-- Search bar -->
        <LinearLayout
            android:id="@+id/llSearchContainer"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:alpha="0.5"
                app:tint="@color/find_gray_text" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="@string/search_anything"
                android:gravity="start|center_vertical"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingHorizontal="8dp"
                android:textSize="14sp"
                android:textColorHint="@color/find_gray_text" />
        </LinearLayout>

        <!-- Top category tabs -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTopTabs"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/surface_tabs"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- Sub-category tabs -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSubTabs"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@color/surface_tabs"
            android:visibility="gone"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- Extra (filter_option) tabs -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvExtraTabs"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@color/surface_tabs"
            android:visibility="gone"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- Filter bar -->
        <LinearLayout
            android:id="@+id/llFilterBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp"
            android:background="@color/surface_tabs"
            android:visibility="gone">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/filter_all"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/bg_chip_selected"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/chipOffer"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/filter_offer"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:textSize="13sp"
                android:textColor="@color/find_gray_text"
                android:background="@drawable/bg_chip_unselected"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/chipRequest"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/filter_request"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:textSize="13sp"
                android:textColor="@color/find_gray_text"
                android:background="@drawable/bg_chip_unselected"
                android:layout_marginEnd="10dp" />

            <Spinner
                android:id="@+id/spinnerRegion"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="32dp"
                android:background="@color/surface_primary" />

            <Spinner
                android:id="@+id/spinnerCity"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:background="@color/white"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Boot shimmer -->
        <LinearLayout
            android:id="@+id/bootShimmer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:visibility="gone">

            <View android:layout_width="80dp" android:layout_height="32dp"
                android:layout_marginEnd="8dp" android:background="@drawable/bg_category_shimmer" />
            <View android:layout_width="100dp" android:layout_height="32dp"
                android:layout_marginEnd="8dp" android:background="@drawable/bg_category_shimmer" />
            <View android:layout_width="120dp" android:layout_height="32dp"
                android:layout_marginEnd="8dp" android:background="@drawable/bg_category_shimmer" />
            <View android:layout_width="70dp" android:layout_height="32dp"
                android:background="@drawable/bg_category_shimmer" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── Content area ── -->
    <FrameLayout
        android:id="@+id/flContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/llStickyHeader"
        app:layout_constraintBottom_toTopOf="@id/cvBottomNav">

            <!-- Case A-1: Top-level category grid (home, no selection) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategoryGrid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="8dp"
                android:paddingTop="8dp"
                android:paddingHorizontal="10dp"
                android:visibility="gone" />

            <!-- Case A-2: Sub-category grid (after tapping a top-level category on home) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSubCategoryGrid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:paddingHorizontal="10dp"
                android:visibility="gone" />

            <!-- Home grid loading spinner -->
            <ProgressBar
                android:id="@+id/pbHomeGrid"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/find_primary"
                android:visibility="gone" />

            <!-- Case B: Listings list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvListings"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:visibility="gone" />

            <!-- Listings shimmer (first page loading) -->
            <LinearLayout
                android:id="@+id/llListingsShimmer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:visibility="gone">

                <include layout="@layout/item_listing_shimmer" />
                <include layout="@layout/item_listing_shimmer" />
                <include layout="@layout/item_listing_shimmer" />
                <include layout="@layout/item_listing_shimmer" />
            </LinearLayout>

            <!-- Empty state with Reset button -->
            <LinearLayout
                android:id="@+id/llEmptyState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😕"
                    android:textSize="52sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/str________________"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/category_title"
                    android:textSize="13sp"
                    android:textColor="@color/find_gray_text"
                    android:gravity="center" />

                <Button
                    android:id="@+id/btnResetFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="20dp"
                    android:text="@string/str____________________"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:backgroundTint="@color/find_primary"
                    android:paddingHorizontal="24dp"
                    style="@style/Widget.MaterialComponents.Button" />
            </LinearLayout>

        </FrameLayout>

    <!-- ── Bottom Nav ── -->
    <include
        android:id="@+id/cvBottomNav"
        layout="@layout/layout_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
