<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">

    <!-- ── Top Bar: Logo & Menu ── -->
    <LinearLayout
        android:id="@+id/llTopBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/llLogoContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_logo_cluster"
                android:contentDescription="Find Logo" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="-4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="find"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="-4dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_menu_circle"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_menu_black"
            android:contentDescription="Menu Button" />
    </LinearLayout>

    <!-- ── Search Bar ── -->
    <LinearLayout
        android:id="@+id/llSearchBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_search_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/llTopBar">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            app:tint="@color/find_gray_text" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:hint="@string/search_hint"
            android:gravity="start|center_vertical"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="8dp"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ── Dynamic Filter Rows ── -->
    <LinearLayout
        android:id="@+id/llFiltersContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/llSearchBar" />

    <!-- ── Filter Bar: type chips + region spinner ── -->
    <HorizontalScrollView
        android:id="@+id/hsvFilterBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:scrollbars="none"
        android:background="#FFF9E6"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/llFiltersContainer">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <Button
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="الكل"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:backgroundTint="@color/find_primary"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/chipOffer"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="عرض"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#EEEEEE"
                android:textColor="@color/text_secondary"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/chipRequest"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="طلب"
                android:textSize="12sp"
                android:layout_marginEnd="12dp"
                android:backgroundTint="#EEEEEE"
                android:textColor="@color/text_secondary"
                style="@style/Widget.MaterialComponents.Button" />

            <Spinner
                android:id="@+id/spinnerRegion"
                android:layout_width="140dp"
                android:layout_height="34dp"
                android:background="@color/white" />

            <Spinner
                android:id="@+id/spinnerCity"
                android:layout_width="140dp"
                android:layout_height="34dp"
                android:layout_marginStart="6dp"
                android:background="@color/white"
                android:visibility="gone" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── Content / Empty State (constrained above nav) ── -->
    <FrameLayout
        android:id="@+id/flContentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/hsvFilterBar"
        app:layout_constraintBottom_toTopOf="@id/cvBottomNav">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMainContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:padding="4dp" />

        <ProgressBar
            android:id="@+id/listingsProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/llEmptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_ads"
                android:textSize="18sp"
                android:textColor="#000000"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_plus_circle"
                    android:padding="16dp"
                    android:src="@drawable/ic_add"
                    app:tint="#000000" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/add_ad"
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- ════════════════════════════════════════════════════════
         BOTTOM NAV  –  floating pill with 3 icons, no labels
         Layout:  [grid]  ···  [+]  ···  [person○]
         ════════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvBottomNav"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="40dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <!-- Find / Home icon -->
            <ImageView
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="28dp"
                android:src="@drawable/find"
                android:scaleType="fitCenter"
                android:contentDescription="Home" />

            <!-- Add button -->
            <ImageView
                android:id="@+id/navAdd"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="28dp"
                android:src="@drawable/add"
                android:scaleType="fitCenter"
                android:contentDescription="Add" />

            <!-- Chat icon -->
            <ImageView
                android:id="@+id/navChat"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="28dp"
                android:src="@drawable/chat"
                android:scaleType="fitCenter"
                android:contentDescription="Chat" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>