<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/surface_primary"
    app:strokeColor="@android:color/black"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layoutDirection="locale">

        <!-- Top: image + info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:orientation="horizontal"
            android:layoutDirection="ltr">

            <!-- Image side (LEFT) -->
            <FrameLayout
                android:layout_width="147dp"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_photo_placeholder" />

                <!-- Prev arrow (‹) on the left side of image -->
                <TextView
                    android:id="@+id/btnPrev"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="8dp"
                    android:background="#88000000"
                    android:gravity="center"
                    android:text="‹"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Next arrow (›) on the right side of image -->
                <TextView
                    android:id="@+id/btnNext"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="8dp"
                    android:background="#88000000"
                    android:gravity="center"
                    android:text="›"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Info side (RIGHT in RTL, LEFT in LTR) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layoutDirection="locale">

                <!-- Title -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:layout_marginBottom="8dp" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                <!-- Price and Seller Name row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp"
                    android:layoutDirection="locale">

                    <!-- Seller avatar and name (LEFT in RTL, RIGHT in LTR) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="start|center_vertical"
                        android:layoutDirection="locale">

                        <ImageView
                            android:id="@+id/ivSellerAvatar"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_avatar_placeholder"
                            android:scaleType="centerCrop" />

                        <TextView
                            android:id="@+id/tvSellerName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>

                    <!-- Price (RIGHT in RTL, LEFT in LTR) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layoutDirection="locale">

                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginEnd="4dp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_riyal"
                            android:contentDescription="@string/price" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Location and Time row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layoutDirection="locale">

                    <!-- Time (LEFT in RTL, RIGHT in LTR) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="start|center_vertical"
                        android:layoutDirection="locale">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_time"
                            android:contentDescription="@string/time" />

                        <TextView
                            android:id="@+id/tvTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="3dp" />
                    </LinearLayout>

                    <!-- Location (RIGHT in RTL, LEFT in LTR) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layoutDirection="locale">

                        <ImageView
                            android:layout_width="11dp"
                            android:layout_height="13dp"
                            android:src="@drawable/ic_location"
                            android:contentDescription="@string/location" />

                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:layout_marginStart="3dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View 
            android:layout_width="match_parent" 
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Bottom actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
            android:paddingHorizontal="16dp"
            android:layoutDirection="locale">

            <!-- Toggle visibility (RIGHT in RTL, LEFT in LTR) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layoutDirection="locale">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchActive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@android:color/white"
                    app:trackTint="#34C759" />

                <TextView
                    android:id="@+id/tvActiveLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#34C759"
                    android:layout_marginStart="8dp"
                    android:text="@string/ad_visible" />
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <!-- Vertical divider -->
            <View 
                android:layout_width="1dp" 
                android:layout_height="60dp"
                android:background="#E0E0E0"
                android:layout_marginHorizontal="16dp" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <!-- Edit and Delete buttons (LEFT in RTL, RIGHT in LTR) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <Button
                    android:id="@+id/btnEdit"
                    android:layout_width="100dp"
                    android:layout_height="36dp"
                    android:minHeight="0dp"
                    android:text="@string/btn_edit"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:backgroundTint="#F5E6D3"
                    app:cornerRadius="8dp"
                    style="@style/Widget.MaterialComponents.Button" />

                <Button
                    android:id="@+id/btnDelete"
                    android:layout_width="100dp"
                    android:layout_height="36dp"
                    android:minHeight="0dp"
                    android:layout_marginTop="6dp"
                    android:text="@string/btn_delete"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#FF3B30"
                    app:cornerRadius="8dp"
                    style="@style/Widget.MaterialComponents.Button" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
