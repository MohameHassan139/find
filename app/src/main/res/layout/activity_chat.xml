<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen"
    android:clipChildren="false"
    android:layoutDirection="locale">

    <!-- Top Bar -->
    <include layout="@layout/layout_appbar_back" />

    <!-- Chat Header (user info) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/surface_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="1dp">

        <ImageView
            android:id="@+id/ivChatAvatar"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_avatar_placeholder"
            android:layout_marginStart="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvChatName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/username_placeholder"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvChatStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_________________100pm"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Messages area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Shimmer loading for messages -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerChat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <include layout="@layout/item_shimmer_message_received" />
                <include layout="@layout/item_shimmer_message_sent" />
                <include layout="@layout/item_shimmer_message_received" />
                <include layout="@layout/item_shimmer_message_sent" />
                <include layout="@layout/item_shimmer_message_received" />
            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- Messages RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMessages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingVertical="12dp"
            android:paddingHorizontal="12dp"
            android:clipToPadding="false"
            android:visibility="gone" />

        <!-- Error State -->
        <LinearLayout
            android:id="@+id/layoutError"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_error"
                android:alpha="0.45" />

            <TextView
                android:id="@+id/tvErrorMsg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/error_occurred"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnRetry"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="24dp"
                android:text="@string/str_______________"
                android:backgroundTint="@color/find_primary"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

    </FrameLayout>

    <!-- Message Input Bar -->
    <LinearLayout
        android:id="@+id/llMessageInputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:background="@color/surface_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="9dp"
        android:paddingBottom="9dp"
        android:elevation="8dp">

        <!-- Send Button -->
        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/bg_send_button"
            android:padding="10dp"
            android:contentDescription="send" />

        <!-- Text input -->
        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_message_input"
            android:gravity="center_vertical|end"
            android:hint="@string/str______________"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:paddingHorizontal="14dp"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine"
            android:maxLines="3" />

        <!-- Attachment (optional) -->
        <ImageButton
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_attach"
            android:background="@drawable/ripple_circle"
            android:padding="6dp"
            android:contentDescription="attach" />
    </LinearLayout>

</LinearLayout>
