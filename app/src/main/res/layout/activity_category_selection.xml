<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <!-- ── Top Bar ── -->
    <include
        layout="@layout/layout_appbar_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <View android:id="@+id/vTopBarShadow" android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/shadow_divider" app:layout_constraintTop_toBottomOf="@id/llAppBar"/>

    <!-- Reusable home header: search + category tabs -->
    <include
        android:id="@+id/llHomeHeader"
        layout="@layout/layout_home_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/vTopBarShadow" />

    <!-- ── Fixed Header Banner (أضف إعلان) ── -->
    <LinearLayout
        android:id="@+id/llHeaderBanner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        android:background="@color/category_banner_bg"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/llHomeHeader">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_add_ad"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── List Content ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingBottom="90dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/llHeaderBanner"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/llListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp">
            <!-- Items injected dynamically here -->
        </LinearLayout>
    </ScrollView>

    <!-- ── Floating Bottom Nav Bar ── -->
    <include
        android:id="@+id/cvBottomNav"
        layout="@layout/layout_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
