<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- 3×3 mini icon grid — fixed height so rowWeight works -->
        <GridLayout
            android:id="@+id/glSubIcons"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:columnCount="3"
            android:rowCount="3"
            android:useDefaultMargins="false">

            <!-- Row 1 -->
            <ImageView android:id="@+id/ivSub0"
                android:layout_width="0dp" android:layout_height="0dp"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:scaleType="fitCenter" android:padding="3dp"
                android:src="@drawable/ic_placeholder_sub" />
            <ImageView android:id="@+id/ivSub1"
                android:layout_width="0dp" android:layout_height="0dp"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:scaleType="fitCenter" android:padding="3dp"
                android:src="@drawable/ic_placeholder_sub" />
            <ImageView android:id="@+id/ivSub2"
                android:layout_width="0dp" android:layout_height="0dp"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:scaleType="fitCenter" android:padding="3dp"
                android:src="@drawable/ic_placeholder_sub" />

            <!-- Row 2 -->
            <ImageView android:id="@+id/ivSub3"
                android:layout_width="0dp" android:layout_height="0dp"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:scaleType="fitCenter" android:padding="3dp"
                android:src="@drawable/ic_placeholder_sub" />
            <ImageView android:id="@+id/ivSub4"
                android:layout_width="0dp" android:layout_height="0dp"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:scaleType="fitCenter" android:padding="3dp"
                android:src="@drawable/ic_placeholder_sub" />
            <ImageView android:id="@+id/ivSub5"
                android:layout_width="0dp" android:layout_height="0dp"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:scaleType="fitCenter" android:padding="3dp"
                android:src="@drawable/ic_placeholder_sub" />

            <!-- Row 3 -->
            <ImageView android:id="@+id/ivSub6"
                android:layout_width="0dp" android:layout_height="0dp"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:scaleType="fitCenter" android:padding="3dp"
                android:src="@drawable/ic_placeholder_sub" />
            <ImageView android:id="@+id/ivSub7"
                android:layout_width="0dp" android:layout_height="0dp"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:scaleType="fitCenter" android:padding="3dp"
                android:src="@drawable/ic_placeholder_sub" />

            <!-- Last slot: "more" dots -->
            <TextView android:id="@+id/tvMoreDots"
                android:layout_width="0dp" android:layout_height="0dp"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:gravity="center"
                android:text="•••"
                android:textSize="10sp"
                android:textColor="#AAAAAA" />

        </GridLayout>

        <!-- Category name -->
        <TextView
            android:id="@+id/tvCategoryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="12sp"
            android:textColor="@color/text_primary" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
